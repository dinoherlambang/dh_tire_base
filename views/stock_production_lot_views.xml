<odoo>
    <record id="view_production_lot_form_tire_base" model="ir.ui.view">
        <field name="name">stock.production.lot.form.tire.base</field>
        <field name="model">stock.production.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='main_group']" position="after">
                <group name="tire_base_flag" string="Classification">
                    <field name="is_tire" readonly="0" force_save="1"/>
                    <field name="tire_status" attrs="{'invisible': [('is_tire', '=', False)]}"/>
                </group>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Tire Information" attrs="{'invisible': [('is_tire', '=', False)]}">
                    <group>
                        <group string="Physical Specs">
                            <field name="tire_brand_id" options="{'no_create_edit': False}"/>
                            <field name="tire_size_id" options="{'no_create_edit': False}"/>
                            <field name="tire_pattern_id" options="{'no_create_edit': False}" context="{'default_brand_id': tire_brand_id}"/>
                        </group>
                        <group string="Performance &amp; History">
                            <field name="retread_count"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
